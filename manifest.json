{
  "manifest_version": 3,
  "name": "AWS URL Prettier",
  "version": "1.1",
  "description": "Cleans AWS console URLs and wraps them in an AWS SSO start URL so shared links go through federated login.",
  "permissions": ["activeTab", "scripting", "clipboardWrite", "storage"],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "options_page": "options.html"
}
